#!/bin/bash

# Load config
CONFIG_FILE="/Users/infinite27/AILCC_PRIME/antigravity_config.json"

if [ ! -f "$CONFIG_FILE" ]; then
  echo "Error: Config file not found at $CONFIG_FILE"
  exit 1
fi

# Ideally we would parse JSON here, but for simplicity/robustness without heavy deps:
# We'll just hardcode the open command for now, echoing the intent.
# In a real scenario, we might use 'jq'.

echo "🚀 Launching Command Center..."

# Open Google
open -a "Google Chrome" "https://www.google.com"

# Open Perplexity
open -a "Google Chrome" "https://www.perplexity.ai"

# Open Local Command Center (assuming it's running or will be)
open -a "Google Chrome" "http://localhost:3000"

echo "✅ Tabs opened."

{
  "system": {
    "name": "AILCC_PRIME",
    "version": "1.1.0",
    "environment": "production",
    "debug": false
  },
  "observability": {
    "log_rotation_days": 7,
    "trace_enabled": true,
    "circuit_breaker": {
      "threshold": 3,
      "timeout_ms": 300000
    }
  },
  "bridge": {
    "output_file": "../../dashboard/public/data/live_status.json",
    "project_root": "../..",
    "intervals": {
      "default_ms": 300000
    },
    "pivots": {
      "github_free_only": true,
      "linear_free_only": true
    }
  },
  "features": {
    "mode6_enabled": true,
    "delta_sync": true,
    "log_streaming": false
  }
}

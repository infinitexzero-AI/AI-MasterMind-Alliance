# AILCC Dashboard — Environment Variables
# Copy this to .env.local and fill in your values

# ─── AI Providers ───
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ─── Academic Access (Mount Allison University) ───
MTA_EMAIL=your.email@mta.ca
MTA_PASSWORD=your_password

# ─── Integrations ───
LINEAR_API_KEY=
VERCEL_TOKEN=
N8N_WEBHOOK_URL=

# ─── Services ───
REDIS_URL=redis://localhost:6379
PLAYWRIGHT_SERVER_URL=http://localhost:3333
FORGE_API_URL=http://localhost:3001

# ─── Security ───
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

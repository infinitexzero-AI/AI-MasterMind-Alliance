{
  "name": "ailcc-mode6",
  "version": "1.0.0",
  "description": "Mode 6 Intent Routing & Multi-Agent Orchestration System for AILCC Framework",
  "main": "automations/mode6/index.ts",
  "scripts": {
    "build": "npm run dashboard:build",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --watch",
    "lint": "eslint 'automations/mode6/**/*.{ts,tsx,js,jsx}'",
    "dashboard:dev": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build",
    "dashboard:start": "next start",
    "type-check": "tsc --noEmit",
    "monitor:dev": "ts-node forge-monitor/server.ts",
    "unified:dev": "concurrently \"npm run dashboard:dev\" \"npm run monitor:dev\""
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "next": "^14.0.0",
    "node-fetch": "^3.3.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^18.2.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.50.0",
    "jest": "^29.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

{
  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "files.exclude": {
    "node_modules": true,
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true,
    "**/build": true,
    "00_Projects": true,
    "01_Areas": true,
    "03_Archives": true,
    "04_Archives": true,
    "05_Communication_Hub": true,
    "06_System": true,
    "07_Comet_Sync": true,
    "08_Mobile_Edge": true
  },
  "search.exclude": {
    "node_modules": true,
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true,
    "03_Archives": true,
    "04_Archives": true,
    "05_Communication_Hub": true
  },
  "files.watcherExclude": {
    "**/node_modules/*/**": true,
    "**/.next/*/**": true

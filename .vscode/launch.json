{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Run Agent System",
            "runtimeExecutable": "npx",
            "runtimeArgs": [
                "ts-node",
                "--project",
                "${workspaceFolder}/01_Areas/Codebases/ailcc/dashboard/tsconfig.agent.json"
            ],
            "program": "${workspaceFolder}/01_Areas/Codebases/ailcc/dashboard/scripts/start_agent_system.ts",
            "cwd": "${workspaceFolder}/01_Areas/Codebases/ailcc/dashboard",
            "console": "integratedTerminal"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome against localhost",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}/01_Areas/Codebases/ailcc/dashboard"
        }
    ]
}
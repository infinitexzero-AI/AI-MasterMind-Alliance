{
  "mcpServers": {
    "GitHub": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "<YOUR_GITHUB_TOKEN_HERE>"
      }
    },
    "Linear": {
      "command": "npx",
      "args": [
        "-y",
        "@mseep/linear-mcp"
      ],
      "env": {
        "LINEAR_API_KEY": "<YOUR_LINEAR_API_KEY_HERE>"
      }
    },
    "Filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/infinite27/AILCC_PRIME"
      ]
    }
  }
}
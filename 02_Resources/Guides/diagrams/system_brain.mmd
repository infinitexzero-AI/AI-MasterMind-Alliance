graph TB
    subgraph "🧠 NEOCORTEX: Conscious Intelligence"
        CLAUDE[Claude<br/>Prefrontal Cortex<br/>Strategic Planning]
        CHATGPT[ChatGPT<br/>Motor Cortex<br/>Code Execution]
        GEMINI[Gemini<br/>Visual Cortex<br/>Multimodal Processing]
        PERPLEXITY[Perplexity<br/>Temporal Lobe<br/>Knowledge Retrieval]
        GROK[Grok<br/>Association Areas<br/>Meta-Coordination]
    end
    
    subgraph "🎭 LIMBIC SYSTEM: Active Processing"
        REDIS[Hippocampus<br/>Shared Memory]
        QUEUE[Thalamus<br/>Message Queue]
        ALERTS[Amygdala<br/>Error Detection]
        PRIORITY[Hypothalamus<br/>Task Prioritization]
    end
    
    subgraph "🫀 BRAINSTEM: Autonomic Functions"
        VALENTINE[Medulla<br/>Valentine Core<br/>API Gateway]
        N8N[Pons<br/>n8n Workflows<br/>Automation Bridge]
        STORAGE[Cerebellum<br/>File Storage<br/>Motor Memory]
    end
    
    subgraph "🧬 PERIPHERAL NERVOUS SYSTEM: Interfaces"
        GITHUB[GitHub<br/>Code Repository]
        LINEAR[Linear<br/>Task Management]
        NOTION[Notion<br/>Documentation]
        GOOGLE[Google Workspace<br/>Collaboration]
    end
    
    %% Conscious to Active
    CLAUDE --> REDIS
    CHATGPT --> REDIS
    GEMINI --> REDIS
    PERPLEXITY --> REDIS
    GROK --> PRIORITY
    
    %% Active to Autonomic
    REDIS --> QUEUE
    QUEUE --> VALENTINE
    ALERTS --> N8N
    PRIORITY --> N8N
    
    %% Autonomic to Peripheral
    VALENTINE --> GITHUB
    VALENTINE --> LINEAR
    N8N --> NOTION
    N8N --> GOOGLE
    STORAGE --> GITHUB
    STORAGE --> GOOGLE
    
    %% Feedback Loops
    GITHUB -.->|Webhooks| N8N
    LINEAR -.->|Status Updates| ALERTS
    NOTION -.->|Content Sync| STORAGE
    GOOGLE -.->|Real-time Data| GEMINI
    

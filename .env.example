# Mode 6 Multi-Agent Orchestration Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================
# Anthropic Claude API
# ============================================
# Get your API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Claude model configuration (optional)
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.7

# ============================================
# OpenAI API
# ============================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# OpenAI model configuration (optional)
OPENAI_MODEL=gpt-4-turbo
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.7

# ============================================
# xAI Grok API
# ============================================
# Get your API key from: https://console.x.ai
XAI_API_KEY=xai-your-key-here

# Grok model configuration (optional)
GROK_MODEL=grok-2
GROK_MAX_TOKENS=4000
GROK_TEMPERATURE=0.7

# ============================================
# Mode 6 Configuration (optional)
# ============================================
# Memory retention settings
MEMORY_TTL_SECONDS=3600
MEMORY_MAX_ENTRIES=10000

# Orchestration settings
MODE6_LOG_LEVEL=info
MODE6_ENABLE_STATS=true
MODE6_CACHE_ENABLED=true

# ============================================
# Testing & Development
# ============================================
# Set NODE_ENV for different behaviors
NODE_ENV=development

# Enable debug logging
DEBUG=ailcc:*

# Use mock mode for adapters (even with API keys set)
# Useful for testing without spending API credits
# FORCE_MOCK_MODE=true

# Mode 6 Agent API Configuration
# Copy this file to .env and fill in your actual API keys

# Anthropic Claude API
# Get key from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-v0-your-key-here

# OpenAI GPT API (optional)
# Get key from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-your-key-here

# xAI Grok API (optional)
# Get key from: https://console.x.ai/
XAI_API_KEY=your-grok-key-here

# Perplexity Comet API (optional, for future integration)
PERPLEXITY_API_KEY=your-comet-key-here

# Environment
NODE_ENV=development
DEBUG=mode6:*

# Optional: Agent timeouts (milliseconds)
AGENT_REQUEST_TIMEOUT=30000
AGENT_STREAM_TIMEOUT=60000

# Optional: Logging level
LOG_LEVEL=info
